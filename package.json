{
  "name": "prism",
  "version": "1.0.0",
  "description": "seleton prototype",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node\" src/server.ts",
    "dev:pg": "nodemon --watch src --ext ts --exec \"ts-node\" src/server-postgres.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:pg": "node dist/server-postgres.js",
    "migrate:json": "ts-node -P tsconfig.scripts.json scripts/migrate-json-to-postgres.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "openai": "^4.100.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.11.10",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
