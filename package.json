{
  "name": "prism",
  "version": "1.0.0",
  "description": "seleton prototype",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node\" src/server.ts",
    "dev:pg": "nodemon --watch src --ext ts --exec \"ts-node\" src/server-postgres.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:pg": "node dist/server-postgres.js",
    "migrate:json": "ts-node -P tsconfig.scripts.json scripts/migrate-json-to-postgres.ts"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "lucide-react": "^0.576.0",
    "node-cron": "^4.2.1",
    "openai": "^4.100.0",
    "pg": "^8.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.11.10",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
